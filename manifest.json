{
  "manifest_version": 3,
  "name": "Amazon Order Extractor",
  "version": "1.0",
  "description": "Extracts amazon order info from the order page.",
  "icons": {
    "48": "icons/border-48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ynab_amazon_order_categorizer@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["tabs", "identity", "storage"],
  "host_permissions": [
      "*://www.amazon.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/auth.js",
    "scripts": ["background/auth.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://www.amazon.com/*"],
      "js": ["order_extractor.js"]
    }
  ]
}